{
  "name": "默认 LLM 助手",
  "description": "minlo run 无参数时使用的 LLM REPL。引用全局 llm 能力；需要环境变量 OPENAI_API_KEY。",
  "abilities": [
    {
      "name": "llm",
      "config": {
        "url": "https://api.openai.com/v1/chat/completions",
        "apiType": "openai",
        "model": "gpt-4",
        "apiKey": "${OPENAI_API_KEY}",
        "temperature": 0.7,
        "prompt": "▸ "
      }
    }
  ]
}
